{
	"id": "quick-access",
	"name": "Quick Access",
	"version": "1.0.4",
	"manifestURI": "https://raw.githubusercontent.com/nnotwen/n-seanime-extensions/master/plugins/Quick%20Access/quick-access.json",
	"language": "typescript",
	"type": "plugin",
	"description": "Adds quick-access links to external anime databases and tracking sites.",
	"author": "nnotwen",
	"icon": "https://raw.githubusercontent.com/nnotwen/n-seanime-extensions/master/plugins/Quick%20Access/icon.png",
	"website": "",
	"lang": "multi",
	"payloadURI": "https://raw.githubusercontent.com/nnotwen/n-seanime-extensions/master/plugins/Quick%20Access/provider.ts",
	"plugin": {
		"version": "1",
		"permissions": {
			"scopes": [],
			"allow": {
				"networkAccess": {
					"allowedDomains": ["animeapi.my.id"],
					"reasoning": "Used for mapping anime to other providers."
				}
			}
		}
	},
	"userConfig": {
		"requiresConfig": true,
		"version": 2,
		"fields": [
			{
				"name": "$order",
				"label": "Button order (use the refcode, separated by comma)",
				"type": "text",
				"default": ""
			},
			{
				"name": "anidb",
				"label": "Display AniDB Quick button (refcode: anidb)",
				"type": "switch",
				"default": "true"
			},
			{
				"name": "ann",
				"label": "Display AnimeNewsNetwork Quick button (refcode: ann)",
				"type": "switch",
				"default": "true"
			},
			{
				"name": "animeplanet",
				"label": "Display AnimePlanet Quick button (refcode: animeplanet)",
				"type": "switch",
				"default": "true"
			},
			{
				"name": "anisearch",
				"label": "Display AniSearch Quick button (refcode: anisearch)",
				"type": "switch",
				"default": "false"
			},
			{
				"name": "annict",
				"label": "Display Annict Quick button (refcode: annict)",
				"type": "switch",
				"default": "false"
			},
			{
				"name": "hikka",
				"label": "Display Hikka Quick button (refcode: hikka)",
				"type": "switch",
				"default": "false"
			},
			{
				"name": "imdb",
				"label": "Display IMDB Quick button (refcode: imdb)",
				"type": "switch",
				"default": "true"
			},
			{
				"name": "kaize",
				"label": "Display Kaize Quick button (refcode: kaize)",
				"type": "switch",
				"default": "false"
			},
			{
				"name": "kitsu",
				"label": "Display Kitsu Quick button (refcode: kitsu)",
				"type": "switch",
				"default": "true"
			},
			{
				"name": "letterboxd",
				"label": "Display Letterboxd Quick button (refcode: letterboxd)",
				"type": "switch",
				"default": "false"
			},
			{
				"name": "livechart",
				"label": "Display LiveChart Quick button (refcode: livechart)",
				"type": "switch",
				"default": "true"
			},
			{
