{
	"id": "traktsync",
	"name": "TraktSync",
	"version": "1.1.4",
	"manifestURI": "https://raw.githubusercontent.com/nnotwen/n-seanime-extensions/master/plugins/TraktSync/traktsync.json",
	"language": "typescript",
	"type": "plugin",
	"description": "Sync your AniList progress to Trakt.tv",
	"author": "nnotwen",
	"icon": "https://raw.githubusercontent.com/nnotwen/n-seanime-extensions/refs/heads/master/plugins/TraktSync/icon.png",
	"website": "https://github.com/nnotwen/n-seanime-extensions",
	"lang": "en",
	"notes": "This is the older version pre 1.2.0. If you have this plugin installed, uninstall the other TraktSync plugin to prevent issues.",
	"payloadURI": "https://raw.githubusercontent.com/nnotwen/n-seanime-extensions/master/plugins/TraktSync/provider.legacy.ts",
	"plugin": {
		"version": "1",
		"permissions": {
			"scopes": ["storage", "anilist"],
			"allow": {
				"networkAccess": {
					"allowedDomains": ["animeapi.my.id"],
					"reasoning": "Used for mapping anime to other providers."
				}
			}
		}
	}
}
